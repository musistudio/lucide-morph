{
  "name": "@musistudio/lucide-morph-workspace",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "build:package": "node scripts/build-packages.mjs && tsc -p tsconfig.package.json && node scripts/sync-package-types.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "test": "npm run test:package",
    "test:package": "npm run build:package && playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vue": "^3.5.39"
  }
}
