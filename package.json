{
  "name": "lucide-morph",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist-package",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist-package/index.js",
  "module": "./dist-package/index.js",
  "types": "./dist-package/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist-package/index.d.ts",
      "import": "./dist-package/index.js"
    },
    "./react": {
      "types": "./dist-package/react.d.ts",
      "import": "./dist-package/react.js"
    },
    "./vue": {
      "types": "./dist-package/vue.d.ts",
      "import": "./dist-package/vue.js"
    },
    "./webcomponent": {
      "types": "./dist-package/webcomponent.d.ts",
      "import": "./dist-package/webcomponent.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "build:package": "vite build --config vite.package.config.ts && tsc -p tsconfig.package.json",
    "prepublishOnly": "npm run build:package",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "vue": ">=3.3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.7.2",
    "vite": "^8.0.16"
  }
}
