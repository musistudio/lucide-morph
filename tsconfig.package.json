{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "./dist-package",
    "rootDir": "./src",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.package.tsbuildinfo"
  },
  "include": [
    "src/index.ts",
    "src/react.tsx",
    "src/vue.ts",
    "src/webcomponent.ts",
    "src/vue-shim.d.ts",
    "src/runtime/**/*.ts",
    "src/morph/lucideGeometry.ts",
    "src/morph/path.ts",
    "src/morph/presetEndpoints.ts",
    "src/morph/presetScenes.ts",
    "src/morph/presets.ts",
    "src/morph/types.ts"
  ]
}
